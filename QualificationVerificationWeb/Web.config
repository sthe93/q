<configuration>
  <configSections>
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false"/>
  </configSections>
  <system.web>
    <authentication mode="Forms">
      <forms loginUrl="~/Admin/Login.aspx" timeout="20" name=".ASPXAUTH" path="/" protection="All" slidingExpiration="true" cookieless="UseCookies" defaultUrl="~/Admin/Request.aspx" cookieSameSite="Lax"/>
    </authentication>
    <sessionState mode="InProc" cookieless="false" timeout="20"/>
    <httpCookies httpOnlyCookies="true" requireSSL="true" sameSite="Lax"/>
    <compilation debug="false" targetFramework="4.8"/>
    <httpRuntime targetFramework="4.6.1" maxRequestLength="1048576"/>
    <pages controlRenderingCompatibilityVersion="3.5">
      <namespaces>
        <add namespace="System.Web.Optimization"/>
      </namespaces>
      <controls>
        <add namespace="AjaxControlToolkit" assembly="AjaxControlToolkit" tagPrefix="ajaxToolkit"/>
        <add assembly="Microsoft.AspNet.Web.Optimization.WebForms" namespace="Microsoft.AspNet.Web.Optimization.WebForms" tagPrefix="webopt"/>
      </controls>
    </pages>
    <httpModules>
      <add name="ApplicationInsightsWebTracking" type="Microsoft.ApplicationInsights.Web.ApplicationInsightsHttpModule, Microsoft.AI.Web"/>
      <add name="ExceptionHandlingModule" type="QualificationVerificationWeb.Helper.ExceptionHandlingModule, QualificationVerificationWeb"/>
    </httpModules>
    <!--<customErrors mode="Off"/>-->
    <customErrors mode="On" redirectMode="ResponseRedirect" defaultRedirect="~/ErrorRouter.aspx">
      <error statusCode="404" redirect="~/ErrorRouter.aspx"/>
      <error statusCode="500" redirect="~/ErrorRouter.aspx"/>
    </customErrors>
  </system.web>
